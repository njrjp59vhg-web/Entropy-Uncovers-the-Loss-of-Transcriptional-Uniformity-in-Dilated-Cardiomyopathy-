#!/bin/bash
#PBS -o scenic_ctx.out
#PBS -e scenic_ctx.err
#PBS -m bea
#PBS -M ao225@ic.ac.uk
#PBS -l select=1:ncpus=26:mem=128gb
#PBS -l walltime=24:00:00

module load miniforge/3
eval "$(~/miniforge3/bin/conda shell.bash hook)"
conda activate ml_age

TSV=/rds/general/user/ao225/home/CardiaFinal/Results/SCENIC/SCENIC_results/lv_adjacencies.tsv
LOOM=/rds/general/user/ao225/home/CardiaFinal/Results/SCENIC/Processed_files/lv_exp.loom
FEATHER10KB=/rds/general/user/ao225/home/CardiaFinal/Data/SCENIC/hg38_10kbp_up_10kbp_down_full_tx_v10_clust.genes_vs_motifs.rankings.feather
FEATHER500BP=/rds/general/user/ao225/home/CardiaFinal/Data/SCENIC/hg38_500bp_up_100bp_down_full_tx_v10_clust.genes_vs_motifs.rankings.feather
MOTIF=/rds/general/user/ao225/home/CardiaFinal/Data/SCENIC/motifs-v10nr_clust-nr.hgnc-m0.001-o0.0.tbl
OUTPUT=/rds/general/user/ao225/home/CardiaFinal/Results/SCENIC/SCENIC_results/lv_regulons.motifs.csv


echo "Job started: $(date)"
echo "Running on: $(hostname)"

pyscenic ctx \
    "$TSV" \
    "$FEATHER10KB" \
    "$FEATHER500BP" \
    --annotations_fname "$MOTIF" \
    --expression_mtx_fname "$LOOM" \
    --output "$OUTPUT" \
    --num_workers 26

echo "Job finished: $(date)"
