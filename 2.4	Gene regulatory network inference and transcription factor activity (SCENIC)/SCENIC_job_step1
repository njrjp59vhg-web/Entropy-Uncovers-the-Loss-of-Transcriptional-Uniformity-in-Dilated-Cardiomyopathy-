module load miniforge/3
eval "$(~/miniforge3/bin/conda shell.bash hook)"
conda activate ml_age

LOOM=/rds/general/user/ao225/home/CardiaFinal/Results/SCENIC/Processed_files/lv_exp.loom
TF=/rds/general/user/ao225/home/CardiaFinal/Data/SCENIC/allTFs_hg38.txt
RESULTS=/rds/general/user/ao225/home/CardiaFinal/Results/SCENIC/SCENIC_results

cp "$LOOM" "$TMPDIR/"
cp "$TF" "$TMPDIR/"
cd "$TMPDIR"

pyscenic grn "$(basename "$LOOM")" "$(basename "$TF")" -o lv_adjacencies.tsv --num_workers 64 --sparse

mkdir -p "$RESULTS"
cp lv_adjacencies.tsv "$RESULTS/"
